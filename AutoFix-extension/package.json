{
  "name": "autofix",
  "displayName": "AutoFix",
  "description": "AI-powered code error detection on save with multi-error support and fix preview",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autofix.clearHistory",
        "title": "AutoFix: Clear Error History"
      },
      {
        "command": "autofix.reloadConfig",
        "title": "AutoFix: Reload Configuration"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "autofixDashboard",
          "name": "AutoFix Dashboard",
          "icon": "$(bug)",
          "contextualTitle": "Error Analysis"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.14.0"
  },
  "dependencies": {
    "axios": "^1.7.0"
  }
}
